# Copy this file to .env and fill in the values
# This file is safe to commit — .env is not

# ── Backend ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/cricket-scoring
PORT=4000
JWT_SECRET=change_this_to_a_strong_random_secret

# ── Frontend ──────────────────────────────────────────────────────────────────
# For local Docker: http://localhost:4000/api/v1
# For server: http://YOUR_SERVER_IP:4000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
